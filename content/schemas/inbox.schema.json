{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "voiceId", "subject", "body", "priority"],
    "properties": {
      "id": { "type": "string" },
      "voiceId": { "type": "string" },
      "subject": { "type": "string" },
      "body": { "type": "string" },
      "condition": {},
      "perType": { "enum": ["OPPORTUNIST", "PRESSURED_EXPANSIONIST", "SECURITY_SEEKER"] },
      "priority": { "type": "number" },
      "cooldownTurns": { "type": "integer" },
      "maxFires": { "type": "integer" },
      "responseOptions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "label"],
          "properties": {
            "id": { "type": "string" },
            "label": { "type": "string" },
            "effects": { "type": "array" }
          }
        }
      }
    }
  }
}
