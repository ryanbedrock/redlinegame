{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "options"],
    "properties": {
      "id": { "type": "string" },
      "options": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "label"],
          "properties": {
            "id": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      }
    }
  }
}
