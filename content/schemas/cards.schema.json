{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "family", "title", "text", "cost", "leadTimeTurns", "rationaleSetId"],
    "properties": {
      "id": { "type": "string" },
      "family": { "enum": ["SIGNAL", "TRACK_LEVEL"] },
      "title": { "type": "string" },
      "text": { "type": "string" },
      "cost": {
        "type": "object",
        "required": ["budget", "politicalCapital"],
        "properties": {
          "budget": { "type": "number" },
          "politicalCapital": { "type": "number" }
        }
      },
      "leadTimeTurns": { "type": "integer", "minimum": 0 },
      "track": { "enum": ["denial", "punishment", "intelligence", "readiness"] },
      "level": { "type": "integer" },
      "signalType": { "enum": ["CHEAP", "SUNK", "TIED_HANDS", "REASSURANCE"] },
      "baseValue": { "type": "number" },
      "offensiveCoded": { "type": "boolean" },
      "tpDelta": { "type": "number" },
      "commitmentSpec": { "type": "object" },
      "availability": {},
      "maxPurchases": { "type": "integer" },
      "cooldownTurns": { "type": "integer" },
      "rationaleSetId": { "type": "string" }
    }
  }
}
